{
    "_metadata": {
        "version": "1.0.0",
        "description": "openSMT default configuration file"
    },
    "gcode_devices": [
        {
            "id": "gcode_1",
            "name": "Main Controller",
            "port": "/dev/ttyUSB0",
            "baudrate": 115200,
            "bytesize": 8,
            "parity": "N",
            "stopbits": 1,
            "timeout": 1.0,
            "enabled": true
        }
    ],
    "cameras": [
        {
            "id": "camera_1",
            "name": "Top Camera",
            "device_index": 0,
            "resolution": {
                "width": 1920,
                "height": 1080
            },
            "dpi_profiles": [
                {
                    "height_mm": 50.0,
                    "dpi_x": 96.0,
                    "dpi_y": 96.0
                },
                {
                    "height_mm": 100.0,
                    "dpi_x": 48.0,
                    "dpi_y": 48.0
                }
            ],
            "active_pipeline": "default",
            "enabled": true
        }
    ],
    "pipeline_directory": "pipelines",
    "application": {
        "language": "en_US",
        "theme": "system",
        "log_level": "INFO",
        "auto_connect_on_startup": false
    }
