{
  "_comment": "openSMT system configuration — unified format (no broker, direct wiring)",

  "boards": {
    "XY": {
      "device": "/dev/marlinXY",
      "baudrate": 250000,
      "bytesize": 8,
      "parity": "N",
      "stopbits": 1,
      "xonxoff": false,
      "rtscts": false,
      "dsrdtr": false
    },
    "AB": {
      "device": "/dev/marlinAB",
      "baudrate": 250000,
      "bytesize": 8,
      "parity": "N",
      "stopbits": 1,
      "xonxoff": false,
      "rtscts": false,
      "dsrdtr": false
    },
    "CD": {
      "device": "/dev/marlinCD",
      "baudrate": 250000,
      "bytesize": 8,
      "parity": "N",
      "stopbits": 1,
      "xonxoff": false,
      "rtscts": false,
      "dsrdtr": false
    }
  },

  "driver": {
    "speed_factor": 100.0,
    "default_velocity": 25000.0,
    "default_homing_velocity": 5000.0,

    "axes": [
      { "axis": "X",  "board": "XY", "gcode_letter": "X" },
      { "axis": "Y",  "board": "XY", "gcode_letter": "Y" },
      { "axis": "Z1", "board": "AB", "gcode_letter": "X" },
      { "axis": "Z2", "board": "AB", "gcode_letter": "Y" },
      { "axis": "Z3", "board": "CD", "gcode_letter": "X" },
      { "axis": "Z4", "board": "CD", "gcode_letter": "Y" },
      { "axis": "R1", "board": "AB", "gcode_letter": "A" },
      { "axis": "R2", "board": "AB", "gcode_letter": "B" },
      { "axis": "R3", "board": "CD", "gcode_letter": "A" },
      { "axis": "R4", "board": "CD", "gcode_letter": "B" }
    ],

    "axis_velocity": {
      "X":  25000.0,  "Y":  25000.0,
      "Z1":  5000.0,  "Z2":  5000.0,  "Z3":  5000.0,  "Z4":  5000.0,
      "R1": 100000.0, "R2": 100000.0, "R3": 100000.0, "R4": 100000.0
    },

    "homing_velocity": {
      "X": 5000.0, "Y": 5000.0,
      "Z1": 2500.0, "Z2": 2500.0, "Z3": 2500.0, "Z4": 2500.0
    },

    "home_groups": {
      "XY":   ["X",  "Y"],
      "Z1Z2": ["Z1", "Z2"],
      "Z3Z4": ["Z3", "Z4"]
    }
  },

  "locations": {
    "park":             { "X": 250.0, "Y": 250.0 },
    "dispose":          { "X": 150.0, "Y": 150.0 },
    "nozzle_change":    { "X": 250.0, "Y":  50.0 },
    "fiducial_main":    { "X": 262.5, "Y": 120.8 },
    "fiducial_second":  { "X": 300.0, "Y": 180.0 },
    "calibration_spot": { "X": 374.7, "Y": 120.8 }
  },

  "camera": {
    "web_host": "0.0.0.0",
    "web_port": 8080,

    "nozzles": [
      {
        "name": "N1",
        "z_axis": "Z1",
        "min_z": -50.0,
        "max_z": 0.0,
        "offset_x": -45.0,
        "offset_y": -100.0,
        "vacuum_valve": { "board": "AB", "io_type": "gpio", "pin": 5 },
        "air_valve": { "board": "AB", "io_type": "gpio", "pin": 6 }
      },
      {
        "name": "N2",
        "z_axis": "Z2",
        "min_z": -50.0,
        "max_z": 0.0,
        "offset_x": -15.0,
        "offset_y": -100.0,
        "vacuum_valve": { "board": "AB", "io_type": "gpio", "pin": 7 }
      },
      {
        "name": "N3",
        "z_axis": "Z3",
        "min_z": -50.0,
        "max_z": 0.0,
        "offset_x": 15.0,
        "offset_y": -100.0,
        "vacuum_valve": { "board": "CD", "io_type": "gpio", "pin": 5 },
        "air_valve": { "board": "CD", "io_type": "gpio", "pin": 6 }
      },
      {
        "name": "N4",
        "z_axis": "Z4",
        "min_z": -50.0,
        "max_z": 0.0,
        "offset_x": 45.0,
        "offset_y": -100.0,
        "vacuum_valve": { "board": "CD", "io_type": "gpio", "pin": 7 }
      }
    ],

    "cameras": [
      {
        "name": "BOTTOM",
        "x": 297.4,
        "y": 66.5,
        "device": "/dev/video0",
        "fps": 10,
        "resolution_dpcm_x": 95.0,
        "resolution_dpcm_y": 95.0,
        "flip_horizontal": false,
        "flip_vertical": false,
        "rotation_deg": 0,
        "lights": {
          "standard": { "board": "XY", "index": 2, "on_value": 2   },
          "spec1":    { "board": "AB", "index": 0, "on_value": 128 },
          "spec2":    { "board": "XY", "index": 4, "on_value": 48  }
        },
        "pipelines": ["DETECT_FIDUCIAL", "MEASURE_COMPONENT"]
      },
      {
        "name": "TOP",
        "device": "/dev/video2",
        "fps": 5,
        "resolution_dpcm_x": 238.0,
        "resolution_dpcm_y": 238.0,
        "flip_horizontal": false,
        "flip_vertical": false,
        "rotation_deg": 90,
        "lights": {
          "standard": { "board": "AB", "index": 1, "on_value": 2  },
          "spec1":    { "board": "AB", "index": 2, "on_value": 64 },
          "spec2":    { "board": "AB", "index": 3, "on_value": 32 }
        },
        "pipelines": ["PASSTHROUGH"]
      }
    ],

    "pipelines": [
      { "name": "PASSTHROUGH",       "type": "passthrough" },
      { "name": "DETECT_FIDUCIAL",   "type": "passthrough" },
      { "name": "MEASURE_COMPONENT", "type": "passthrough" }
    ]
  }
}
