{
  "type": "camera_vision",
  "name": "CAMERA",
  "web_host": "0.0.0.0",
  "web_port": 8080,
  "gcode_target": "GCODE",
  "head_target": "HEAD",
  "head_nozzles": ["N1", "N2", "N3", "N4"],
  "nozzle_z_axis_map": {
    "N1": "Z1",
    "N2": "Z2",
    "N3": "Z3",
    "N4": "Z4"
  },
  "nozzle_limits": {
    "N1": {"min_z": -50.0, "max_z": 0.0},
    "N2": {"min_z": -50.0, "max_z": 0.0},
    "N3": {"min_z": -50.0, "max_z": 0.0},
    "N4": {"min_z": -50.0, "max_z": 0.0}
  },

  "cameras": [
    {
      "name": "BOTTOM",
      "device": "/dev/video0",
      "fps": 10,
      "resolution_dpcm_x": 95.0,
      "resolution_dpcm_y": 95.0,
      "flip_horizontal": false,
      "flip_vertical": false,
      "rotation_deg": 0,
      "pipelines": ["DETECT_FIDUCIAL", "MEASURE_COMPONENT"]
    },
    {
      "name": "TOP",
      "device": "/dev/video2",
      "fps": 5,
      "resolution_dpcm_x": 238.0,
      "resolution_dpcm_y": 238.0,
      "flip_horizontal": false,
      "flip_vertical": false,
      "rotation_deg": 89.5,
      "pipelines": ["PASSTHROUGH"]
    }
  ],

  "pipelines": [
    { "name": "PASSTHROUGH",       "type": "passthrough" },
    { "name": "DETECT_FIDUCIAL",   "type": "passthrough" },
    { "name": "MEASURE_COMPONENT", "type": "passthrough" }
  ]
}
