{
  "type": "camera_vision",
  "name": "CAMERA",
  "web_port": 8080,

  "cameras": [
    {
      "name": "TOP",
      "device": 0,
      "fps": 10,
      "lights": {
        "standard": ":GCODE:ANOUT:2 64",
        "spec1":    ":GCODE:ANOUT:3 128",
        "spec2":    ":GCODE:ANOUT:4 48"
      },
      "pipelines": ["DETECT_FIDUCIAL", "MEASURE_COMPONENT"]
    },
    {
      "name": "SIDE",
      "device": 1,
      "fps": 5,
      "lights": {
        "standard": ":GCODE:ANOUT:5 48",
        "spec1":    ":GCODE:ANOUT:6 64",
        "spec2":    ":GCODE:ANOUT:7 32"
      },
      "pipelines": ["PASSTHROUGH"]
    }
  ],

  "pipelines": [
    { "name": "PASSTHROUGH",       "type": "passthrough" },
    { "name": "DETECT_FIDUCIAL",   "type": "passthrough" },
    { "name": "MEASURE_COMPONENT", "type": "passthrough" }
  ]
}
