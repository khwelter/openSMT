# Python bytecode/cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Test/type/lint caches and coverage output
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# IDE/OS metadata
.vscode/
.idea/
.DS_Store

# Logs and temporary runtime files
*.log
tmp/*
!tmp/.gitkeep

# SQLite sidecar/runtime files
*.sqlite-wal
*.sqlite-shm
*.db-wal
*.db-shm
config/examples/catalog.sqlite

# Generated vision pipeline diagnostic images and counters
diagnostics/*.jpg
diagnostics/*.jpeg
diagnostics/*.JPG
diagnostics/*.JPEG
diagnostics/counter.txt
